# Copy to .env locally, or add each as a "Secret" in Replit (Tools → Secrets).
# Replit sets PORT automatically — you usually don't need to set it.

# ── Required ──────────────────────────────────────────────
# Secret for signing login tokens. Generate one:  openssl rand -hex 32
JWT_SECRET=

# The email that should be the application owner (super-admin).
# Comma-separated for multiple. This account sees the /admin.html panel.
SUPER_ADMIN_EMAILS=you@youragency.com

# ── AI (optional — agencies can also bring their own key in-app) ──
# Global fallback key, also settable later in the Admin panel → Global Settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_REPLIES_PER_HOUR=10

# ── Trials ──
TRIAL_DAYS=7

# ── Public URL (for Stripe redirects / links). Set to your deployed URL. ──
BASE_URL=

# ── Stripe (only if you charge agencies for the app itself) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Production persistence (Replit Reserved VM) ──
# DATA_DIR: set this on PRODUCTION only. It (a) selects the production KV
#   backup key (zaply_prod_sqlite_db_v1) so dev can never overwrite prod, and
#   (b) relocates runtime files. Leave UNSET in dev.
DATA_DIR=
# REPLIT_DB_URL: Replit's KV endpoint. Auto-injected in dev, but NOT in a
#   Reserved VM deployment — copy the dev value and set it as a prod env var,
#   or DB backups won't run.
REPLIT_DB_URL=
# ZAPLY_UNLIMITED=1 removes trial expiry, the monthly conversation quota, and
#   the per-chat hourly AI cap. Use for self-hosted / personal deployments.
ZAPLY_UNLIMITED=
# AI_MAX_REPLIES_PER_HOUR: per-chat hourly AI cap (default 30; 1000 when
#   ZAPLY_UNLIMITED=1). Override here if needed.
AI_MAX_REPLIES_PER_HOUR=
